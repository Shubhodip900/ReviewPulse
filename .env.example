# PR Review Agent Configuration
 
# GitHub API Token
# Create at: https://github.com/settings/tokens
# Required scopes: repo (read/write access to code)
GITHUB_TOKEN=ghp_your_github_token_here

# Anthropic API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# Optional: Custom API endpoint (for organizations using custom endpoints)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional: Model selection (defaults to claude-3-5-sonnet-20241022)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Optional: Maximum number of comments per review (default: 30)
# MAX_COMMENTS=30

# Optional: Post comments to GitHub (set to true to enable)
# POST_COMMENTS=false

# Optional: Skills file path (defaults to ./skills/skill.md)
# SKILLS_PATH=./skills/skill.md